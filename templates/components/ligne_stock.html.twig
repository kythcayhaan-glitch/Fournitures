{% set is_low = article.stockQuantity <= article.stockMinimum %}
<tr class="cursor-pointer {{ is_low ? 'stock-bas' : '' }}" onclick="window.location='{{ path('app_admin_inventaire_ajuster', {id: article.id}) }}'">
    <td>
        <strong>{{ article.name }}</strong>
        <br><small class="text-muted">{{ article.reference }}</small>
    </td>
    <td>{{ article.category ? article.category.name : '—' }}</td>
    <td class="text-center">
        <span class="badge {{ is_low ? 'bg-danger' : 'bg-success' }} fs-6">
            {{ article.stockQuantity }}
        </span>
        <small class="text-muted">/ {{ article.unit }}</small>
    </td>
    <td class="text-center text-muted">{{ article.stockMinimum }}</td>
    <td class="text-center">
        {% if is_low %}
            <span class="badge bg-danger"><i class="bi bi-exclamation-triangle"></i> Stock bas</span>
        {% else %}
            <span class="badge bg-success"><i class="bi bi-check"></i> OK</span>
        {% endif %}
    </td>
    {% if show_actions ?? false %}
    <td onclick="event.stopPropagation()">
        <a href="{{ path('app_admin_inventaire_ajuster', {id: article.id}) }}"
           class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-pencil"></i> Ajuster
        </a>
    </td>
    {% endif %}
</tr>
