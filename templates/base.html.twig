<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Gestion Fournitures Bureau{% endblock %}</title>

    {# Bootstrap 5 CDN #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --sidebar-width: 250px;
            --primary-color: #0d6efd;
        }
        body { background-color: #f8f9fa; }
        .sidebar {
            width: var(--sidebar-width);
            min-height: 100vh;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        }
        .sidebar .nav-link { color: rgba(255,255,255,.75); border-radius: 8px; margin: 2px 8px; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { color: #fff; background: rgba(255,255,255,.15); }
        .sidebar .nav-link i { width: 20px; }
        .sidebar-header { padding: 1.5rem 1rem; border-bottom: 1px solid rgba(255,255,255,.1); }
        .main-content { min-height: 100vh; }
        .card { border: none; box-shadow: 0 0 15px rgba(0,0,0,.08); }
        .badge-statut { font-size: .75rem; }
        .stock-bas { background-color: #fff3cd !important; }
        .table > :not(caption) > * > * { padding: .65rem .75rem; }
        .breadcrumb { background: transparent; padding: 0; margin-bottom: 1rem; }
        @media (max-width: 768px) {
            .sidebar { display: none; }
        }
    </style>

    {% block stylesheets %}{% endblock %}
</head>
<body>

{% if app.user %}
<div class="d-flex">
    {# ── Sidebar ── #}
    <nav class="sidebar d-flex flex-column flex-shrink-0 p-0">
        <div class="sidebar-header">
            <a href="{{ path('app_dashboard') }}" class="text-white text-decoration-none d-flex align-items-center gap-2">
                <i class="bi bi-box-seam fs-4"></i>
                <span class="fw-bold">Fournitures</span>
            </a>
            <small class="text-white-50">{{ app.user.fullName }}</small>
        </div>

        <ul class="nav nav-pills flex-column mt-3 flex-grow-1">
            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_dashboard' %}active{% endif %}"
                   href="{{ path('app_dashboard') }}">
                    <i class="bi bi-speedometer2"></i> Tableau de bord
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_demande' %}active{% endif %}"
                   href="{{ path('app_demande_index') }}">
                    <i class="bi bi-clipboard-list"></i> Mes demandes
                </a>
            </li>

            {% if is_granted('ROLE_MANAGER') %}
            <li class="mt-2 px-3 text-white-50 small text-uppercase fw-bold">Manager</li>
            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_manager' %}active{% endif %}"
                   href="{{ path('app_manager_index') }}">
                    <i class="bi bi-check2-square"></i> Toutes les demandes
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="{{ path('app_manager_stock') }}">
                    <i class="bi bi-boxes"></i> Vue stock
                </a>
            </li>
            {% endif %}

            {% if is_granted('ROLE_ADMIN') %}
            <li class="mt-2 px-3 text-white-50 small text-uppercase fw-bold">Administration</li>
            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_admin_fournitures' %}active{% endif %}"
                   href="{{ path('app_admin_fournitures') }}">
                    <i class="bi bi-box"></i> Fournitures
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_admin_categories' %}active{% endif %}"
                   href="{{ path('app_admin_categories') }}">
                    <i class="bi bi-tags"></i> Catégories
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') == 'app_admin_users' %}active{% endif %}"
                   href="{{ path('app_admin_users') }}">
                    <i class="bi bi-people"></i> Utilisateurs
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_admin_inventaire' %}active{% endif %}"
                   href="{{ path('app_admin_inventaire') }}">
                    <i class="bi bi-clipboard-data"></i> Inventaire
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') == 'app_admin_historique' %}active{% endif %}"
                   href="{{ path('app_admin_historique') }}">
                    <i class="bi bi-clock-history"></i> Historique stock
                </a>
            </li>
            {% endif %}
        </ul>

        <div class="p-3 border-top border-secondary mt-auto">
            <a href="{{ path('app_logout') }}" class="nav-link text-danger">
                <i class="bi bi-box-arrow-left"></i> Déconnexion
            </a>
        </div>
    </nav>

    {# ── Main content ── #}
    <div class="flex-grow-1 main-content">
        <nav class="navbar navbar-light bg-white border-bottom px-4 py-2">
            <span class="navbar-text text-muted small">
                {% block page_title %}{% endblock %}
            </span>
            <span class="navbar-text">
                <i class="bi bi-person-circle"></i>
                <strong>{{ app.user.fullName }}</strong>
                {% for role in app.user.roles %}
                    {% if role != 'ROLE_USER' %}
                        <span class="badge bg-secondary ms-1 small">{{ role }}</span>
                    {% endif %}
                {% endfor %}
            </span>
        </nav>

        <div class="container-fluid p-4">
            {# Breadcrumb #}
            {% block breadcrumb %}{% endblock %}

            {# Flash messages #}
            {% for type, messages in app.flashes %}
                {% set alertClass = {'success': 'success', 'error': 'danger', 'warning': 'warning', 'info': 'info'}[type] ?? 'info' %}
                {% for message in messages %}
                    <div class="alert alert-{{ alertClass }} alert-dismissible fade show" role="alert">
                        <i class="bi bi-{% if type == 'success' %}check-circle{% elseif type == 'error' %}exclamation-triangle{% else %}info-circle{% endif %}"></i>
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </div>
    </div>
</div>
{% else %}
    {# Layout pour pages non authentifiées #}
    <div class="container">
        {{ block('body') }}
    </div>
{% endif %}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
