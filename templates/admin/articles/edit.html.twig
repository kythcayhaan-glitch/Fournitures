{% extends 'base.html.twig' %}

{% block title %}Modifier {{ article.name }}{% endblock %}
{% block page_title %}<i class="bi bi-pencil"></i> Modifier un article{% endblock %}

{% block breadcrumb %}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}">Tableau de bord</a></li>
        <li class="breadcrumb-item"><a href="{{ path('app_admin_articles') }}">Articles</a></li>
        <li class="breadcrumb-item active">{{ article.reference }}</li>
    </ol>
</nav>
{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Modifier : {{ article.name }}</h5>
                <span class="badge bg-secondary">{{ article.reference }}</span>
            </div>
            <div class="card-body">
                {{ form_start(form) }}
                <div class="row g-3">
                    <div class="col-md-8">{{ form_row(form.name) }}</div>
                    <div class="col-md-4">{{ form_row(form.reference) }}</div>
                    <div class="col-12">{{ form_row(form.description) }}</div>
                    <div class="col-md-4">{{ form_row(form.unitPrice) }}</div>
                    <div class="col-md-4">{{ form_row(form.unit) }}</div>
                    <div class="col-md-4">{{ form_row(form.stockMinimum) }}</div>
                    <div class="col-md-8">{{ form_row(form.category) }}</div>
                </div>
                <div class="alert alert-info mt-3 small">
                    <i class="bi bi-info-circle"></i>
                    Stock actuel : <strong>{{ article.stockQuantity }} {{ article.unit }}</strong>
                    (modifiable via <a href="{{ path('app_admin_inventaire_ajuster', {id: article.id}) }}">l'inventaire</a>)
                </div>
                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Enregistrer
                    </button>
                    <a href="{{ path('app_admin_articles') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Retour
                    </a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
