{% extends 'base.html.twig' %}

{% block title %}Utilisateurs{% endblock %}
{% block page_title %}<i class="bi bi-people"></i> Utilisateurs{% endblock %}

{% block breadcrumb %}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}">Tableau de bord</a></li>
        <li class="breadcrumb-item active">Utilisateurs</li>
    </ol>
</nav>
{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Gestion des utilisateurs
        <span class="text-muted fs-6 fw-normal ms-2">{{ users|length }} utilisateur(s)</span>
    </h4>
    <a href="{{ path('app_admin_users_new') }}" class="btn btn-primary btn-sm">
        <i class="bi bi-person-plus"></i> Ajouter un utilisateur
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nom</th>
                    <th>Rôles</th>
                    <th class="text-center">Statut</th>
                    <th>Inscrit le</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                <tr class="{{ not user.isActive ? 'table-secondary opacity-75' : '' }}">
                    <td>
                        <strong>{{ user.fullName }}</strong>
                        {% if user == app.user %}
                            <span class="badge bg-primary ms-1 small">Vous</span>
                        {% endif %}
                    </td>
                    <td>
                        {% for role in user.roles %}
                            {% if role != 'ROLE_USER' %}
                                <span class="badge bg-secondary small">{{ role }}</span>
                            {% endif %}
                        {% endfor %}
                        <span class="badge bg-light text-dark border small">ROLE_USER</span>
                    </td>
                    <td class="text-center">
                        {% if user.isActive %}
                            <span class="badge bg-success"><i class="bi bi-check"></i> Actif</span>
                        {% else %}
                            <span class="badge bg-secondary"><i class="bi bi-x"></i> Inactif</span>
                        {% endif %}
                    </td>
                    <td class="text-muted small">{{ user.createdAt|date('d/m/Y') }}</td>
                    <td class="text-center">
                        {% if user != app.user %}
                        <div class="d-flex gap-2 justify-content-center align-items-center">
                            <a href="{{ path('app_admin_users_edit', {id: user.id}) }}"
                               class="btn btn-sm btn-outline-secondary" title="Modifier">
                                <i class="bi bi-pencil"></i>
                            </a>
                            {# Sélecteur de rôle #}
                            <form method="post"
                                  action="{{ path('app_admin_users_set_role', {id: user.id}) }}"
                                  class="d-flex gap-1 align-items-center">
                                <input type="hidden" name="_token" value="{{ csrf_token('set_role_' ~ user.id) }}">
                                {% set currentRole = 'ROLE_USER' %}
                                {% if 'ROLE_ADMIN' in user.roles %}
                                    {% set currentRole = 'ROLE_ADMIN' %}
                                {% elseif 'ROLE_MANAGER' in user.roles %}
                                    {% set currentRole = 'ROLE_MANAGER' %}
                                {% endif %}
                                <select name="role" class="form-select form-select-sm" style="width:auto;">
                                    <option value="ROLE_USER"    {{ currentRole == 'ROLE_USER'    ? 'selected' }}>Utilisateur</option>
                                    <option value="ROLE_MANAGER" {{ currentRole == 'ROLE_MANAGER' ? 'selected' }}>Manager</option>
                                    <option value="ROLE_ADMIN"   {{ currentRole == 'ROLE_ADMIN'   ? 'selected' }}>Admin</option>
                                </select>
                                <button type="submit" class="btn btn-sm btn-outline-primary" title="Appliquer">
                                    <i class="bi bi-check2"></i>
                                </button>
                            </form>
                            {# Activation / Désactivation #}
                            <form method="post"
                                  action="{{ path('app_admin_users_toggle', {id: user.id}) }}"
                                  onsubmit="return confirm('{{ user.isActive ? 'Désactiver' : 'Activer' }} cet utilisateur ?')"
                                  class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('toggle_user_' ~ user.id) }}">
                                <button type="submit"
                                        class="btn btn-sm {{ user.isActive ? 'btn-outline-danger' : 'btn-outline-success' }}"
                                        title="{{ user.isActive ? 'Désactiver' : 'Activer' }}">
                                    <i class="bi {{ user.isActive ? 'bi-person-x' : 'bi-person-check' }}"></i>
                                </button>
                            </form>
                            {# Suppression #}
                            <form method="post"
                                  action="{{ path('app_admin_users_delete', {id: user.id}) }}"
                                  onsubmit="return confirm('Supprimer définitivement {{ user.fullName }} ?')"
                                  class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.id) }}">
                                <button type="submit" class="btn btn-sm btn-danger" title="Supprimer">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </form>
                        </div>
                        {% else %}
                        <span class="text-muted small">—</span>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
