{% extends 'base.html.twig' %}

{% block title %}Nouvelle fourniture{% endblock %}
{% block page_title %}<i class="bi bi-plus-circle"></i> Nouvelle fourniture{% endblock %}

{% block breadcrumb %}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}">Tableau de bord</a></li>
        <li class="breadcrumb-item"><a href="{{ path('app_admin_fournitures') }}">Fournitures</a></li>
        <li class="breadcrumb-item active">Nouvelle</li>
    </ol>
</nav>
{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header"><h5 class="mb-0">Créer une fourniture</h5></div>
            <div class="card-body">
                {{ form_start(form) }}
                <div class="row g-3">
                    <div class="col-md-8">{{ form_row(form.name) }}</div>
                    <div class="col-md-4">{{ form_row(form.reference) }}</div>
                    <div class="col-12">{{ form_row(form.description) }}</div>
                    <div class="col-md-4">{{ form_row(form.unitPrice) }}</div>
                    <div class="col-md-4">{{ form_row(form.unit) }}</div>
                    <div class="col-md-4">{{ form_row(form.stockMinimum) }}</div>
                    <div class="col-md-8">{{ form_row(form.category) }}</div>
                    <div class="col-md-4 d-flex align-items-end">{{ form_row(form.isActive) }}</div>
                </div>
                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Créer
                    </button>
                    <a href="{{ path('app_admin_fournitures') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-x"></i> Annuler
                    </a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
