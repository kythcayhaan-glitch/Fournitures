{% extends 'base.html.twig' %}

{% block title %}Gestion des fournitures{% endblock %}
{% block page_title %}<i class="bi bi-box"></i> Fournitures{% endblock %}

{% block breadcrumb %}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}">Tableau de bord</a></li>
        <li class="breadcrumb-item active">Fournitures</li>
    </ol>
</nav>
{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Catalogue des fournitures</h4>
    <a href="{{ path('app_admin_fournitures_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Nouvelle fourniture
    </a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <input type="text" name="search" class="form-control form-control-sm"
                       placeholder="Nom ou référence..." value="{{ search ?? '' }}">
            </div>
            <div class="col-md-4">
                <select name="category" class="form-select form-select-sm">
                    <option value="">Toutes catégories</option>
                    {% for cat in categories %}
                    <option value="{{ cat.id }}">{{ cat.name }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-filter"></i> Filtrer
                </button>
                <a href="{{ path('app_admin_fournitures') }}" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-x"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Référence</th>
                        <th>Nom</th>
                        <th>Catégorie</th>
                        <th class="text-center">Stock</th>
                        <th class="text-center">Min.</th>
                        <th class="text-center">Statut</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for fourniture in pagination %}
                    <tr class="{{ fourniture.isStockBas ? 'table-warning' : '' }}">
                        <td class="text-muted small">{{ fourniture.reference }}</td>
                        <td>
                            <strong>{{ fourniture.name }}</strong>
                            {% if fourniture.isStockBas %}
                                <span class="badge bg-danger ms-1 small">Stock bas</span>
                            {% endif %}
                        </td>
                        <td>{{ fourniture.category.name }}</td>
                        <td class="text-center">
                            <span class="badge {{ fourniture.isStockBas ? 'bg-danger' : 'bg-success' }}">
                                {{ fourniture.stockQuantity }}
                            </span>
                            <small class="text-muted">{{ fourniture.unit }}</small>
                        </td>
                        <td class="text-center text-muted">{{ fourniture.stockMinimum }}</td>
                        <td class="text-center">
                            {% if fourniture.isActive %}
                                <span class="badge bg-success">Active</span>
                            {% else %}
                                <span class="badge bg-secondary">Inactive</span>
                            {% endif %}
                        </td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm">
                                <a href="{{ path('app_admin_fournitures_edit', {id: fourniture.id}) }}"
                                   class="btn btn-outline-primary" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="{{ path('app_admin_inventaire_ajuster', {id: fourniture.id}) }}"
                                   class="btn btn-outline-secondary" title="Ajuster stock">
                                    <i class="bi bi-clipboard-data"></i>
                                </a>
                                <form method="post"
                                      action="{{ path('app_admin_fournitures_delete', {id: fourniture.id}) }}"
                                      onsubmit="return confirm('Désactiver cette fourniture ?')"
                                      class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_fourniture_' ~ fourniture.id) }}">
                                    <button type="submit" class="btn btn-outline-danger" title="Désactiver">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        <div class="d-flex justify-content-center py-3">
            {{ knp_pagination_render(pagination) }}
        </div>
    </div>
</div>
{% endblock %}
