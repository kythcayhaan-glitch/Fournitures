{% extends 'base.html.twig' %}
{% block title %}Modifier {{ category.name }}{% endblock %}
{% block page_title %}<i class="bi bi-tag"></i> Modifier la catégorie{% endblock %}
{% block breadcrumb %}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}">Tableau de bord</a></li>
        <li class="breadcrumb-item"><a href="{{ path('app_admin_categories') }}">Catégories</a></li>
        <li class="breadcrumb-item active">{{ category.name }}</li>
    </ol>
</nav>
{% endblock %}
{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header"><h5 class="mb-0">Modifier : {{ category.name }}</h5></div>
            <div class="card-body">
                {{ form_start(form) }}
                {{ form_row(form.name) }}
                {{ form_row(form.description) }}
                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Enregistrer</button>
                    <a href="{{ path('app_admin_categories') }}" class="btn btn-outline-secondary">Retour</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
