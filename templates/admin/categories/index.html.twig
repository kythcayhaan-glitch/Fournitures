{% extends 'base.html.twig' %}

{% block title %}Catégories{% endblock %}
{% block page_title %}<i class="bi bi-tags"></i> Catégories{% endblock %}

{% block breadcrumb %}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}">Tableau de bord</a></li>
        <li class="breadcrumb-item active">Catégories</li>
    </ol>
</nav>
{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Catégories d'articles</h4>
    <a href="{{ path('app_admin_categories_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Nouvelle catégorie
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nom</th>
                    <th>Description</th>
                    <th class="text-center">Articles</th>
                    <th>Créée le</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for row in categories %}
                {% set cat = row[0] is defined ? row[0] : row.category %}
                {% set count = row[1] is defined ? row[1] : row.articleCount %}
                <tr>
                    <td><strong>{{ cat.name }}</strong></td>
                    <td class="text-muted small">{{ cat.description ?? '—' }}</td>
                    <td class="text-center">
                        <span class="badge bg-primary">{{ count }}</span>
                    </td>
                    <td class="text-muted small">{{ cat.createdAt|date('d/m/Y') }}</td>
                    <td class="text-center">
                        <div class="btn-group btn-group-sm">
                            <a href="{{ path('app_admin_categories_edit', {id: cat.id}) }}"
                               class="btn btn-outline-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post"
                                  action="{{ path('app_admin_categories_delete', {id: cat.id}) }}"
                                  onsubmit="return confirm('Supprimer cette catégorie ?')"
                                  class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_category_' ~ cat.id) }}">
                                <button type="submit" class="btn btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
