{% extends 'base.html.twig' %}

{% block title %}Vue Stock{% endblock %}
{% block page_title %}<i class="bi bi-boxes"></i> Gestion du stock{% endblock %}

{% block breadcrumb %}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}">Tableau de bord</a></li>
        <li class="breadcrumb-item active">Vue stock</li>
    </ol>
</nav>
{% endblock %}

{% block body %}

{% if stocksBas|length > 0 %}
<div class="alert alert-danger d-flex align-items-center gap-2">
    <i class="bi bi-exclamation-triangle-fill fs-4"></i>
    <div><strong>{{ stocksBas|length }} article(s) en stock bas !</strong> Une commande de réapprovisionnement est recommandée.</div>
</div>
{% endif %}

<div class="d-flex justify-content-between align-items-center mb-3">
    <form method="post" action="{{ path('app_manager_articles_bulk_delete') }}" id="bulk-delete-form"
          onsubmit="return confirm('Supprimer définitivement les ' + document.querySelectorAll('.article-checkbox:checked').length + ' articles sélectionnés ?')">
        <input type="hidden" name="_token" value="{{ csrf_token('bulk_delete_articles') }}">
        <div id="bulk-inputs"></div>
        <button type="submit" class="btn btn-sm btn-outline-danger" id="btn-bulk-delete" disabled>
            <i class="bi bi-trash"></i> Supprimer la sélection (<span id="bulk-count">0</span>)
        </button>
    </form>
    <div class="d-flex gap-2">
        <a href="{{ path('app_admin_historique') }}" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-clock-history"></i> Historique
        </a>
        <a href="{{ path('app_admin_articles_new') }}" class="btn btn-sm btn-primary">
            <i class="bi bi-plus-lg"></i> Nouvel article
        </a>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2 align-items-center">
            <input type="text" name="search" class="form-control form-control-sm"
                   placeholder="Rechercher..." value="{{ search ?? '' }}">
            <select name="category" class="form-select form-select-sm" style="min-width:160px" onchange="this.form.submit()">
                <option value="">Toutes catégories</option>
                {% for cat in categories %}
                <option value="{{ cat.id }}" {{ categoryId == cat.id ? 'selected' : '' }}>{{ cat.name }}</option>
                {% endfor %}
            </select>
            <button type="submit" class="btn btn-sm btn-outline-primary text-nowrap">
                <i class="bi bi-filter"></i> Filtrer
            </button>
            <a href="{{ path('app_manager_stock') }}" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-x"></i>
            </a>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 32px"><input type="checkbox" id="select-all" class="form-check-input"></th>
                        <th>Article</th>
                        <th>Catégorie</th>
                        <th class="text-center">Stock</th>
                        <th class="text-center">Min.</th>
                        <th class="text-center">Statut</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for article in pagination %}
                    {% set is_low = article.stockQuantity <= article.stockMinimum %}
                    <tr class="cursor-pointer {{ is_low ? 'stock-bas' : '' }}" onclick="window.location='{{ path('app_admin_articles_edit', {id: article.id}) }}'">
                        <td onclick="event.stopPropagation()">
                            <input type="checkbox" class="article-checkbox form-check-input" value="{{ article.id }}">
                        </td>
                        <td><strong>{{ article.name }}</strong> <small class="text-muted">{{ article.reference }}</small></td>
                        <td>{{ article.category ? article.category.name : '—' }}</td>
                        <td class="text-center">
                            <span class="badge {{ is_low ? 'bg-danger' : 'bg-success' }}">
                                {{ article.stockQuantity }}
                            </span>
                            <small class="text-muted">{{ article.unit }}</small>
                        </td>
                        <td class="text-center text-muted">{{ article.stockMinimum }}</td>
                        <td class="text-center">
                            {% if is_low %}
                                <span class="badge bg-danger"><i class="bi bi-exclamation-triangle"></i> Stock bas</span>
                            {% else %}
                                <span class="badge bg-success"><i class="bi bi-check"></i> OK</span>
                            {% endif %}
                        </td>
                        <td class="text-center" onclick="event.stopPropagation()">
                            <div class="btn-group btn-group-sm">
                                <a href="{{ path('app_admin_articles_edit', {id: article.id}) }}"
                                   class="btn btn-outline-primary" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="{{ path('app_admin_inventaire_ajuster', {id: article.id}) }}"
                                   class="btn btn-outline-secondary" title="Ajuster stock">
                                    <i class="bi bi-clipboard-data"></i>
                                </a>
                                <form method="post"
                                      action="{{ path('app_admin_articles_delete', {id: article.id}) }}"
                                      onsubmit="return confirm('Supprimer définitivement {{ article.name|e('js') }} ?')"
                                      class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_article_' ~ article.id) }}">
                                    <button type="submit" class="btn btn-outline-danger" title="Supprimer">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        <div class="d-flex justify-content-center py-3">
            {{ knp_pagination_render(pagination) }}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
    const checkboxes = document.querySelectorAll('.article-checkbox');
    const selectAll = document.getElementById('select-all');
    const btnBulkDelete = document.getElementById('btn-bulk-delete');
    const bulkCount = document.getElementById('bulk-count');
    const bulkInputs = document.getElementById('bulk-inputs');

    function majSelection() {
        const coches = document.querySelectorAll('.article-checkbox:checked');
        bulkCount.textContent = coches.length;
        btnBulkDelete.disabled = coches.length === 0;
    }

    checkboxes.forEach(function (cb) {
        cb.addEventListener('change', majSelection);
    });

    selectAll.addEventListener('change', function () {
        checkboxes.forEach(function (cb) { cb.checked = selectAll.checked; });
        majSelection();
    });

    document.getElementById('bulk-delete-form').addEventListener('submit', function () {
        bulkInputs.innerHTML = '';
        document.querySelectorAll('.article-checkbox:checked').forEach(function (cb) {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'ids[]';
            input.value = cb.value;
            bulkInputs.appendChild(input);
        });
    });
</script>
{% endblock %}
