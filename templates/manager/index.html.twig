{% extends 'base.html.twig' %}

{% block title %}Gestion des demandes{% endblock %}
{% block page_title %}<i class="bi bi-check2-square"></i> Gestion des demandes{% endblock %}

{% block breadcrumb %}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}">Tableau de bord</a></li>
        <li class="breadcrumb-item active">Gestion des demandes</li>
    </ol>
</nav>
{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">
        Toutes les demandes
        {% if nbEnAttente > 0 %}
            <span class="badge bg-warning text-dark ms-2">{{ nbEnAttente }} en attente</span>
        {% endif %}
    </h4>
    {% if is_granted('ROLE_ADMIN') %}
    <form method="post"
          action="{{ path('app_admin_demandes_delete_all') }}"
          onsubmit="return confirm('Supprimer TOUTES les demandes ? Le stock ne sera pas modifié.')">
        <input type="hidden" name="_token" value="{{ csrf_token('delete_all_demandes') }}">
        <button type="submit" class="btn btn-sm btn-outline-danger">
            <i class="bi bi-trash3"></i> Supprimer toutes
        </button>
    </form>
    {% endif %}
</div>

{# Filtres #}
<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Statut</label>
                <select name="statut" class="form-select form-select-sm">
                    <option value="">Tous</option>
                    <option value="pending" {{ statut == 'pending' ? 'selected' : '' }}>En attente</option>
                    <option value="rejected" {{ statut == 'rejected' ? 'selected' : '' }}>Rejetées</option>
                    <option value="delivered" {{ statut == 'delivered' ? 'selected' : '' }}>Livrées</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Du</label>
                <input type="date" name="from" class="form-control form-control-sm"
                       value="{{ from ? from|date('Y-m-d') : '' }}">
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Au</label>
                <input type="date" name="to" class="form-control form-control-sm"
                       value="{{ to ? to|date('Y-m-d') : '' }}">
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-filter"></i> Filtrer
                </button>
                <a href="{{ path('app_manager_index') }}" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-x"></i> Reset
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        {% if pagination.totalItemCount == 0 %}
            <p class="text-muted text-center py-5">Aucune demande trouvée.</p>
        {% else %}
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Référence</th>
                            <th>Demandeur</th>
                            <th>Date</th>
                            <th class="text-center">Statut</th>
                            <th class="text-center">Articles</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for demande in pagination %}
                        <tr>
                            <td>
                                <a href="{{ path('app_demande_show', {id: demande.id}) }}" class="fw-semibold text-decoration-none">
                                    {{ demande.reference }}
                                </a>
                            </td>
                            <td>{{ demande.requester.fullName }}</td>
                            <td class="text-muted small">{{ demande.requestedAt|date('d/m/Y H:i') }}</td>
                            <td class="text-center">
                                {{ include('components/badge_statut.html.twig', {statut: demande.statut}) }}
                            </td>
                            <td class="text-center">{{ demande.lignes|length }}</td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <a href="{{ path('app_demande_show', {id: demande.id}) }}"
                                       class="btn btn-outline-secondary" title="Voir">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    {% if demande.isPending %}
                                    <a href="{{ path('app_manager_process', {id: demande.id}) }}"
                                       class="btn btn-outline-warning" title="Traiter">
                                        <i class="bi bi-check2-square"></i>
                                    </a>
                                    {% endif %}
                                    {% if is_granted('ROLE_ADMIN') %}
                                    <form method="post"
                                          action="{{ path('app_admin_demande_delete', {id: demande.id}) }}"
                                          onsubmit="return confirm('Supprimer la demande {{ demande.reference }} ?')"
                                          class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_demande_' ~ demande.id) }}">
                                        <button type="submit" class="btn btn-outline-danger" title="Supprimer">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="d-flex justify-content-center py-3">
                {{ knp_pagination_render(pagination) }}
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
