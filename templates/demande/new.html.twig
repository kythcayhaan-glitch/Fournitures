{% extends 'base.html.twig' %}

{% block title %}Nouvelle demande{% endblock %}
{% block page_title %}<i class="bi bi-plus-circle"></i> Nouvelle demande{% endblock %}

{% block breadcrumb %}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}">Tableau de bord</a></li>
        <li class="breadcrumb-item"><a href="{{ path('app_demande_index') }}">Mes demandes</a></li>
        <li class="breadcrumb-item active">Nouvelle demande</li>
    </ol>
</nav>
{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-clipboard-plus"></i> Nouvelle demande de matériel</h5>
            </div>
            <div class="card-body">
                {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

                <div class="row fw-semibold small text-muted mb-1 px-1">
                    <div class="col">Fourniture</div>
                    <div class="col-auto" style="width:110px">Quantité</div>
                    <div class="col-auto" style="width:42px"></div>
                </div>

                <div id="lignes-container" data-prototype="{{ form_widget(form.lignes.vars.prototype)|e('html_attr') }}">
                    {% for ligne in form.lignes %}
                    <div class="ligne-demande d-flex align-items-center gap-2 mb-2">
                        <div class="flex-grow-1">
                            {{ form_widget(ligne.fourniture) }}
                            {{ form_errors(ligne.fourniture) }}
                        </div>
                        <div style="width:110px">
                            {{ form_widget(ligne.quantiteDemandee) }}
                            {{ form_errors(ligne.quantiteDemandee) }}
                        </div>
                        <div>
                            <button type="button" class="btn btn-sm btn-outline-danger remove-ligne" title="Supprimer">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                    {% endfor %}
                </div>

                <div id="no-lignes-msg" class="alert alert-warning mt-2 {% if form.lignes|length > 0 %}d-none{% endif %}">
                    <i class="bi bi-exclamation-circle"></i> Veuillez ajouter au moins un article.
                </div>

                <button type="button" id="add-ligne" class="btn btn-outline-primary btn-sm mt-2 mb-4">
                    <i class="bi bi-plus-lg"></i> Ajouter un article
                </button>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-send"></i> Soumettre la demande
                    </button>
                    <a href="{{ path('app_demande_index') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-x"></i> Annuler
                    </a>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {
    const container = document.getElementById('lignes-container');
    const addBtn    = document.getElementById('add-ligne');
    const noMsg     = document.getElementById('no-lignes-msg');
    let index = container.querySelectorAll('.ligne-demande').length;

    function updateMsg() {
        noMsg.classList.toggle('d-none', container.querySelectorAll('.ligne-demande').length > 0);
    }

    function buildLigne(html) {
        const tmp = document.createElement('div');
        tmp.innerHTML = html;

        const select = tmp.querySelector('select');
        const input  = tmp.querySelector('input[type="number"], input[type="text"]');

        if (select) select.className = 'form-select';
        if (input)  { input.className = 'form-control'; input.min = 1; }

        const row = document.createElement('div');
        row.className = 'ligne-demande d-flex align-items-center gap-2 mb-2';

        const colF = document.createElement('div');
        colF.className = 'flex-grow-1';
        if (select) colF.appendChild(select);

        const colQ = document.createElement('div');
        colQ.style.width = '110px';
        if (input) colQ.appendChild(input);

        const colB = document.createElement('div');
        colB.innerHTML = '<button type="button" class="btn btn-sm btn-outline-danger remove-ligne" title="Supprimer"><i class="bi bi-trash"></i></button>';

        row.appendChild(colF);
        row.appendChild(colQ);
        row.appendChild(colB);

        return row;
    }

    function attachRemove(ligne) {
        ligne.querySelector('.remove-ligne').addEventListener('click', function () {
            ligne.remove();
            updateMsg();
        });
    }

    container.querySelectorAll('.ligne-demande').forEach(attachRemove);

    addBtn.addEventListener('click', function () {
        const html = container.dataset.prototype.replace(/__name__/g, index++);
        const ligne = buildLigne(html);
        container.appendChild(ligne);
        attachRemove(ligne);
        updateMsg();
    });

    updateMsg();
});
</script>
{% endblock %}
