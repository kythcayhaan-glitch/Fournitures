{% extends 'base.html.twig' %}

{% block title %}Mes demandes{% endblock %}
{% block page_title %}<i class="bi bi-clipboard-list"></i> Mes demandes{% endblock %}

{% block breadcrumb %}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}">Tableau de bord</a></li>
        <li class="breadcrumb-item active">Mes demandes</li>
    </ol>
</nav>
{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Mes demandes de matériel</h4>
    <a href="{{ path('app_demande_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Nouvelle demande
    </a>
</div>

{# Filtres #}
<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Statut</label>
                <select name="statut" class="form-select form-select-sm">
                    <option value="">Tous les statuts</option>
                    <option value="pending" {{ statut == 'pending' ? 'selected' : '' }}>En attente</option>
                    <option value="rejected" {{ statut == 'rejected' ? 'selected' : '' }}>Rejetées</option>
                    <option value="delivered" {{ statut == 'delivered' ? 'selected' : '' }}>Livrées</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Depuis le</label>
                <input type="date" name="from" class="form-control form-control-sm"
                       value="{{ from ? from|date('Y-m-d') : '' }}">
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-filter"></i> Filtrer
                </button>
                <a href="{{ path('app_demande_index') }}" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-x"></i> Réinitialiser
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        {% if pagination.totalItemCount == 0 %}
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                <p>Aucune demande trouvée.</p>
                <a href="{{ path('app_demande_new') }}" class="btn btn-primary">
                    Créer ma première demande
                </a>
            </div>
        {% else %}
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Référence</th>
                            <th>Date</th>
                            <th class="text-center">Statut</th>
                            <th class="text-center">Articles</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for demande in pagination %}
                        <tr>
                            <td>
                                <a href="{{ path('app_demande_show', {id: demande.id}) }}" class="fw-semibold text-decoration-none">
                                    {{ demande.reference }}
                                </a>
                            </td>
                            <td class="text-muted small">{{ demande.requestedAt|date('d/m/Y H:i') }}</td>
                            <td class="text-center">
                                {{ include('components/badge_statut.html.twig', {statut: demande.statut}) }}
                            </td>
                            <td class="text-center">{{ demande.lignes|length }}</td>
                            <td class="text-end" onclick="event.stopPropagation()">
                                <div class="btn-group btn-group-sm">
                                    <a href="{{ path('app_demande_show', {id: demande.id}) }}"
                                       class="btn btn-outline-secondary" title="Voir">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    {% if demande.isPending and is_granted('DEMANDE_EDIT', demande) %}
                                    <a href="{{ path('app_demande_edit', {id: demande.id}) }}"
                                       class="btn btn-outline-primary" title="Modifier">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_demande_delete_user', {id: demande.id}) }}"
                                          onsubmit="return confirm('Supprimer cette demande ?')" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_demande_user_' ~ demande.id) }}">
                                        <button type="submit" class="btn btn-outline-danger" title="Supprimer">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="d-flex justify-content-center py-3">
                {{ knp_pagination_render(pagination) }}
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
