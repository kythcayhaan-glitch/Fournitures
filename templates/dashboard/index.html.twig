{% extends 'base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}
{% block page_title %}<i class="bi bi-speedometer2"></i> Tableau de bord{% endblock %}

{% block breadcrumb %}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item active">Tableau de bord</li>
    </ol>
</nav>
{% endblock %}

{% block body %}

{# ── Cartes résumé ── #}
{% if is_granted('ROLE_MANAGER') %}
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <a href="{{ path('app_manager_index', {statut: 'pending'}) }}" class="text-decoration-none">
        <div class="card border-0 bg-warning bg-opacity-10 h-100 cursor-pointer">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-warning rounded-3 p-3 text-white">
                    <i class="bi bi-hourglass-split fs-4"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">{{ statsParStatut['pending'] ?? 0 }}</div>
                    <div class="text-muted small">En attente</div>
                </div>
            </div>
        </div>
        </a>
    </div>
    <div class="col-sm-6 col-lg-3">
        <a href="{{ path('app_manager_index', {statut: 'rejected'}) }}" class="text-decoration-none">
        <div class="card border-0 bg-danger bg-opacity-10 h-100 cursor-pointer">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-danger rounded-3 p-3 text-white">
                    <i class="bi bi-x-circle fs-4"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">{{ statsParStatut['rejected'] ?? 0 }}</div>
                    <div class="text-muted small">Rejetées</div>
                </div>
            </div>
        </div>
        </a>
    </div>
    <div class="col-sm-6 col-lg-3">
        <a href="{{ path('app_manager_index', {statut: 'delivered'}) }}" class="text-decoration-none">
        <div class="card border-0 bg-success bg-opacity-10 h-100 cursor-pointer">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-success rounded-3 p-3 text-white">
                    <i class="bi bi-truck fs-4"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">{{ statsParStatut['delivered'] ?? 0 }}</div>
                    <div class="text-muted small">Livrées</div>
                </div>
            </div>
        </div>
        </a>
    </div>
    <div class="col-sm-6 col-lg-3">
        <a href="{{ path('app_admin_inventaire') }}" class="text-decoration-none">
        <div class="card border-0 bg-danger bg-opacity-10 h-100 cursor-pointer">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-danger rounded-3 p-3 text-white">
                    <i class="bi bi-exclamation-triangle fs-4"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">{{ stocksBas|length }}</div>
                    <div class="text-muted small">Articles stock bas</div>
                </div>
            </div>
        </div>
        </a>
    </div>
</div>
{% endif %}

{% if is_granted('ROLE_MANAGER') and demandesEnAttente is not empty %}
<div class="card mb-3 border-warning">
    <div class="card-header bg-warning bg-opacity-10 d-flex justify-content-between align-items-center">
        <h6 class="mb-0"><i class="bi bi-hourglass-split text-warning"></i> Demandes en attente de traitement
            <span class="badge bg-warning text-dark ms-2">{{ demandesEnAttente|length }}</span>
        </h6>
        <a href="{{ path('app_manager_index', {statut: 'pending'}) }}" class="btn btn-sm btn-outline-warning">Voir toutes</a>
    </div>
    <div class="card-body p-0">
        <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Référence</th>
                    <th>Demandeur</th>
                    <th>Date</th>
                    <th class="text-center">Articles</th>
                    <th class="text-center">Action</th>
                </tr>
            </thead>
            <tbody>
                {% for demande in demandesEnAttente %}
                <tr class="cursor-pointer" onclick="window.location='{{ path('app_demande_show', {id: demande.id}) }}'">
                    <td class="fw-semibold">{{ demande.reference }}</td>
                    <td>{{ demande.requester.fullName }}</td>
                    <td class="text-muted small">{{ demande.requestedAt|date('d/m/Y H:i') }}</td>
                    <td class="text-center">{{ demande.lignes|length }}</td>
                    <td class="text-center">
                        <a href="{{ path('app_manager_process', {id: demande.id}) }}"
                           class="btn btn-sm btn-warning" onclick="event.stopPropagation()">
                            <i class="bi bi-check2-square"></i> Traiter
                        </a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0"><i class="bi bi-clipboard-list"></i> Mes demandes</h6>
        <a href="{{ path('app_demande_new') }}" class="btn btn-sm btn-primary">
            <i class="bi bi-plus"></i> Nouvelle demande
        </a>
    </div>
    <div class="card-body p-0">
        {% if mesDemandes is empty %}
            <p class="text-muted text-center py-4">Aucune demande</p>
        {% else %}
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Référence</th>
                        <th>Date</th>
                        <th class="text-center">Statut</th>
                        <th class="text-center">Articles</th>
                    </tr>
                </thead>
                <tbody>
                    {% for demande in mesDemandes %}
                    <tr class="cursor-pointer" onclick="window.location='{{ path('app_demande_show', {id: demande.id}) }}'">
                        <td class="fw-semibold">{{ demande.reference }}</td>
                        <td class="text-muted small">{{ demande.requestedAt|date('d/m/Y H:i') }}</td>
                        <td class="text-center">{{ include('components/badge_statut.html.twig', {statut: demande.statut}) }}</td>
                        <td class="text-center">{{ demande.lignes|length }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
    <div class="card-footer">
        <a href="{{ path('app_demande_index') }}" class="btn btn-sm btn-outline-secondary">Voir toutes</a>
    </div>
</div>

<div class="row g-3">
    {# ── Alertes stock bas ── #}
    {% if is_granted('ROLE_MANAGER') %}
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-exclamation-triangle text-danger"></i> Articles en stock bas</h6>
                {% if stocksBas|length > 3 %}
                    <a href="{{ path('app_admin_inventaire') }}" class="btn btn-sm btn-outline-danger">
                        Voir les {{ stocksBas|length }} articles
                    </a>
                {% endif %}
            </div>
            <div class="card-body p-0">
                {% if stocksBas is empty %}
                    <p class="text-muted text-center py-4">
                        <i class="bi bi-check-circle text-success fs-3 d-block mb-2"></i>
                        Tous les stocks sont à niveau
                    </p>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Article</th>
                                    <th class="text-center">Stock</th>
                                    <th class="text-center">Min.</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for article in stocksBas|slice(0, 3) %}
                                {% if is_granted('ROLE_MANAGER') %}
                                <tr class="stock-bas cursor-pointer" onclick="window.location='{{ path('app_admin_articles_edit', {id: article.id}) }}'">
                                {% else %}
                                <tr class="stock-bas">
                                {% endif %}
                                    <td>
                                        <span class="fw-semibold">{{ article.name }}</span>
                                        <br><small class="text-muted">{{ article.reference }}</small>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-danger">{{ article.stockQuantity }}</span>
                                    </td>
                                    <td class="text-center text-muted">{{ article.stockMinimum }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
    {% endif %}

    {# ── Mouvements récents ── #}
    {% if is_granted('ROLE_MANAGER') %}
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-clock-history"></i> Mouvements de stock récents</h6>
            </div>
            <div class="card-body p-0">
                {% if mouvementsRecents is empty %}
                    <p class="text-muted text-center py-3">Aucun mouvement récent</p>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Article</th>
                                    <th>Type</th>
                                    <th class="text-center">Qté</th>
                                    <th>Motif</th>
                                    <th>Opérateur</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for m in mouvementsRecents %}
                                <tr>
                                    <td class="text-muted small">{{ m.createdAt|date('d/m/Y H:i') }}</td>
                                    <td><strong>{{ m.article.name }}</strong></td>
                                    <td>
                                        <span class="badge {{ m.type.badgeClass() }}">{{ m.type.label() }}</span>
                                    </td>
                                    <td class="text-center">
                                        {% if m.type.value == 'entree' %}
                                            <span class="text-success">+{{ m.quantite }}</span>
                                        {% else %}
                                            <span class="text-danger">-{{ m.quantite }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-muted small">{{ m.motif|u.truncate(50, '…') }}</td>
                                    <td class="small">{{ m.operateur.fullName }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
    {% endif %}
</div>

{% endblock %}
